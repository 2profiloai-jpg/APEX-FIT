rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, displayName, email, readinessScore, lastSync, preferences
    
    // Collection: exercises
    // Fields: id, name, category, targetMuscles, videoUrl, instructions
    
    // Collection: users/{userId}/sessions
    // Fields: id, userId, startTime, endTime, exercises[]
    
    // Collection: users/{userId}/biometrics
    // Fields: userId, date, hrv, sleepHours, stressLevel
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['userId', 'startTime']) &&
             data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin (manual) can write exercises for now
    }

    match /users/{userId}/sessions/{sessionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSession(request.resource.data);
      allow update: if isOwner(userId) && isValidSession(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/plans/{planId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/biometrics/{logId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /users/{userId}/meals/{mealId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/favoriteMeals/{favId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
  }
}
